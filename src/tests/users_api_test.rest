########################################
# HORÁRIOS DE TRABALHO
########################################

### Criar horário de trabalho do profissional (sucesso - admin)
POST {{baseUrl}}/profissionais/1/horarios
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "dia_semana": 1,
  "hora_inicio": "08:00",
  "hora_fim": "18:00"
}

###

### Criar horário - segundo dia da semana (para variar disponibilidade nos testes)
POST {{baseUrl}}/profissionais/1/horarios
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "dia_semana": 3,
  "hora_inicio": "09:00",
  "hora_fim": "17:00"
}

###

### Criar horário sem token -> esperado 401
POST {{baseUrl}}/profissionais/1/horarios
Content-Type: application/json

{
  "dia_semana": 1,
  "hora_inicio": "08:00",
  "hora_fim": "18:00"
}

###

### Criar horário com token de cliente (não-admin) -> esperado 403
POST {{baseUrl}}/profissionais/1/horarios
Content-Type: application/json
Authorization: Bearer {{clienteToken}}

{
  "dia_semana": 1,
  "hora_inicio": "08:00",
  "hora_fim": "18:00"
}

###

### Criar horário com campos faltando -> esperado 400
POST {{baseUrl}}/profissionais/1/horarios
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "dia_semana": 1,
  "hora_inicio": "08:00"
}

###

### Listar horários do profissional (rota pública)
GET {{baseUrl}}/profissionais/1/horarios

###

### Listar horários de profissional sem nenhum horário cadastrado -> esperado []
GET {{baseUrl}}/profissionais/999/horarios

###

### Deletar horário (sucesso - ajustar :id conforme retorno do POST acima)
DELETE {{baseUrl}}/profissionais/1/horarios/1
Authorization: Bearer {{adminToken}}

###

### Deletar horário inexistente -> esperado 404
DELETE {{baseUrl}}/profissionais/1/horarios/9999
Authorization: Bearer {{adminToken}}

###

### Deletar horário sem token -> esperado 401
DELETE {{baseUrl}}/profissionais/1/horarios/1

###

